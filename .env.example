# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=sx_hris_db
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false  # Set to true for Supabase or other cloud PostgreSQL providers

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_EXPIRATION=3600

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
TIMEZONE=UTC

# i18n Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,fr,de,es,ja,zh
