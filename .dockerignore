# Docker ignore file for SX-HRIS Backend
# Files and directories to exclude from Docker build context

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Distribution
dist/
build/

# Environment files (use .env.production in Dockerfile explicitly)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
pm2-*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/
test-results/

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
docs/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Misc
.prettierrc
.eslintrc.js
.editorconfig
jest.config.js
